<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<Pane prefHeight="300.0" prefWidth="500.0" styleClass="app-background" stylesheets="@app.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="core.ui.LoginController">
   <children>
    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="300.0" prefWidth="500.0" styleClass="app-background">
         <children>
            <HBox alignment="CENTER" layoutY="30.0" prefWidth="500.0" />
            <HBox alignment="CENTER" layoutY="74.0" prefWidth="500.0">
               <children>
                  <AnchorPane maxHeight="-Infinity" minHeight="-Infinity" prefHeight="172.0" prefWidth="332.0" styleClass="login-card">
                     <children>
               <GridPane alignment="CENTER" layoutX="35.0" layoutY="-1.0" prefHeight="152.0" prefWidth="298.0">
              <columnConstraints>
                <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                  <RowConstraints maxHeight="182.0" minHeight="10.0" prefHeight="8.0" vgrow="SOMETIMES" />
                  <RowConstraints maxHeight="182.0" minHeight="0.0" prefHeight="46.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="182.0" minHeight="3.0" prefHeight="45.0" vgrow="SOMETIMES" />
               <RowConstraints maxHeight="152.0" minHeight="0.0" prefHeight="44.0" valignment="CENTER" vgrow="SOMETIMES" />
                  <RowConstraints maxHeight="152.0" minHeight="0.0" prefHeight="24.0" valignment="TOP" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Button alignment="CENTER" contentDisplay="CENTER" defaultButton="true" mnemonicParsing="false" onAction="#tryLogin" prefHeight="25.0" prefWidth="124.0" styleClass="primary-button" stylesheets="@app.css" text="Log In" GridPane.rowIndex="3">
                     <font>
                        <Font name="Onest Regular" size="12.0" />
                     </font></Button>
                  <TextField fx:id="emailField" prefHeight="25.0" prefWidth="298.0" promptText="Enter your email" styleClass="auth-input" GridPane.rowIndex="1">
                     <font>
                        <Font name="Onest Regular" size="12.0" />
                     </font></TextField>
                  <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="auth-input" GridPane.rowIndex="2">
                     <GridPane.margin>
                        <Insets top="8.0" />
                     </GridPane.margin>
                     <font>
                        <Font name="Onest Regular" size="12.0" />
                     </font></PasswordField>
                  <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="25.0" prefWidth="124.0" styleClass="inactive-button" text="Register" GridPane.rowIndex="4">
                     <font>
                        <Font name="Onest Regular" size="12.0" />
                     </font>
                  </Button>
               </children>
                  </GridPane>
                     </children>
                  </AnchorPane>
               </children>
            </HBox>
            <Text layoutX="89.0" layoutY="52.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="login-title" text="Welcome to your StudiSave">
               <font>
                  <Font name="Onest Bold" size="24.0" />
               </font>
            </Text>
         </children>
      </AnchorPane>
   </children>
</Pane>
